# Obsidian Manager — Environment Configuration

# Required: path to your Obsidian vault
OBSIDIAN_VAULT_PATH=/path/to/your/vault

# Optional: source directories
OBSIDIAN_SOURCES_DIR=/path/to/your/vault/kb/raw

# Optional: wiki categories (comma-separated)
OBSIDIAN_CATEGORIES=concepts,sources

# Optional: lint schedule (manual | daily | weekly)
LINT_SCHEDULE=manual
